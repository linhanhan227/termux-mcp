# Required for tavily_search.
TAVILY_API_KEY=tvly-your-key

# Optional configuration.
TAVILY_API_URL=https://api.tavily.com/search
MCP_SERVER_NAME=python-mcp-toolkit
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_STATELESS_HTTP=true
MCP_WORKSPACE=.
MCP_AUTH_TOKEN=
MCP_AUTH_HEADER=X-MCP-Auth-Token
MCP_ALLOW_WRITE=false
MCP_ENABLE_SHELL=false
MCP_MAX_FILE_BYTES=2097152
MCP_REQUEST_TIMEOUT=20

# Comma-separated plugin modules, for example:
# MCP_TOOLKIT_PLUGINS=examples.custom_tools
MCP_TOOLKIT_PLUGINS=
